{
  "name": "syslog-ai",
  "version": "1.0.7",
  "description": "AI-Powered Windows System Log Analyzer — วิเคราะห์ปัญหาระบบ Windows ด้วย AI (Gemini, Claude, GPT, etc.)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder build",
    "dist:win": "electron-builder build --win --x64",
    "dist:mac": "electron-builder build --mac",
    "dist:portable": "electron-builder build --win --x64 --config.win.target=portable"
  },
  "author": "pppoipoit",
  "license": "MIT",
  "allowScripts": {
    "electron@33.4.11": true,
    "electron-builder@*": true,
    "app-builder-lib@*": true,
    "dmg-builder@*": true
  },
  "build": {
    "appId": "com.syslog-ai.app",
    "productName": "SysLog AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer.js",
      "preload.js",
      "index.html",
      "styles.css",
      "package.json",
      "src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "extraResources": [
        {
          "from": "build/icon.ico",
          "to": "icon.ico"
        },
        {
          "from": "src/collector/",
          "to": "src/collector/"
        }
      ],
      "asar": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon.ico",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "artifactName": "${productName}-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "SysLog AI",
      "uninstallDisplayName": "SysLog AI — Windows System Log Analyzer",
      "language": "1046"
    }
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8"
  }
}
